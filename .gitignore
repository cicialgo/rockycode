results/predictions/
results/runs/
results/*.jsonl
logs/
/raw-*.json
/rockycode-*.json

# rockycode runtime (trajectories, artifacts, local config)
.rockycode/

# OS
.DS_Store

# Editors
.vscode/
.idea/
*.swp
