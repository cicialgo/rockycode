# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# Virtual envs
.venv/
venv/
.python-version

# Env / secrets
.env
.env.local
.env.*.local

# Caches
.cache/
.pytest_cache/
.ruff_cache/
